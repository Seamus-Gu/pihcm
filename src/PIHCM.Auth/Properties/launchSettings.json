{
    "profiles": {
        "PIHCM.Auth": {
            "commandName": "Project",
            "environmentVariables": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "dotnetRunMessages": true,
            "applicationUrl": "https://localhost:5010;http://localhost:19010"
        },
        "Container": {
            "commandName": "Docker",
            "launchBrowser": false,
            "environmentVariables": {
                "ASPNETCORE_URLS": "https://+:443;http://+:80"
            },
            "httpPort": 19010,
            "sslPort": 5010,
            "useSSL": true,
            "containerRunArguments": "--network pihcm --name pihcm_auth"
        }
    },
    "$schema": "https://json.schemastore.org/launchsettings.json"
}