            "DangerousAcceptAnyServerCertificateValidator": true
        },
        {
            "UseServiceDiscovery": true,
            "DownstreamPathTemplate": "/{everything}",
            "DownstreamScheme": "https",
            "ServiceName": "PIHCM.Core",
